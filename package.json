{
  "name": "syn9-asp",
  "version": "0.1.0",
  "description": "Syn9 — provenance-verified, permissioned collaborative state layer for multi-agent workflows on OKX AI.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/api/server.js",
  "scripts": {
    "dev": "node --watch --env-file=.env src/api/server.js",
    "start": "node --env-file=.env src/api/server.js",
    "migrate": "node --env-file=.env src/modules/storage/migrate.js",
    "test": "node --test tests/unit/**/*.test.js",
    "test:integration": "node --env-file=.env --test tests/integration/**/*.test.js"
  },
  "dependencies": {
    "@fastify/sensible": "^6.0.1",
    "fastify": "^5.1.0",
    "pg": "^8.22.0",
    "pino": "^9.5.0"
  }
