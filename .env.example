# ── Server ────────────────────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Storage module (modules/storage) ─────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/syn9
DATABASE_POOL_MAX=10

# ── Identity module (modules/identity) ───────────────────────────────
# v1 auth: API key + X-Agent-Wallet header (see blueprint R2 — wallet-native
# signature verification is TEE-internal only, not publicly verifiable in v1).
SYN9_API_KEY_SALT=change-me

# ── Synthesis module (modules/synthesis) ─────────────────────────────
ANTHROPIC_API_KEY=
SYNTHESIS_MODEL=claude-sonnet-4-6

# ── Embeddings (used by storage module for similarity search) ───────
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# ── Anchor module (modules/anchor) ───────────────────────────────────
XLAYER_RPC_URL=
XLAYER_ANCHOR_CONTRACT=
XLAYER_SIGNER_PRIVATE_KEY=
SEPOLIA_RPC_URL=
ANCHOR_BATCH_INTERVAL_MINUTES=10

# ── Payment (x402 / OKX Payment SDK) ─────────────────────────────────
OKX_PAYMENT_SDK_KEY=
X402_FACILITATOR_URL=